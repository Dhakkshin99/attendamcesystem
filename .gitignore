# ==========================================================================
# 1. DEPENDENCIES & LIBRARIES
# ==========================================================================
# Third-party modules installed via npm/yarn/pnpm
node_modules/

# Logs generated by package managers during install/errors
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================================
# 2. ENVIRONMENT SECRETS (CRITICAL)
# ==========================================================================
# Absolute priority: Never push database URIs, API keys, or JWT tokens to GitHub
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Serverless or cloud provider configuration secrets
.serverless/
.dynamodb/

# ==========================================================================
# 3. COMPILATION OUTPUTS & CACHES
# ==========================================================================
# If you are using TypeScript or a builder (like Babel or esbuild)
dist/
build/
out/

# Testing framework coverage metrics
coverage/
.nyc_output/

# Application execution logs (if your code outputs log files)
logs/
*.log

# ==========================================================================
# 4. SYSTEM & EDITOR CONFIGS
# ==========================================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
.DS_Store
Thumbs.db