# ==========================================================================
# 1. DEPENDENCIES & PACKAGE MANAGERS
# ==========================================================================
# Ignores third-party packages in root, frontend, and backend folders
node_modules/
**/node_modules/
jspm_packages/
web_modules/

# Package manager logs and error caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================================
# 2. ENVIRONMENT CONFIGURATIONS & SECRETS (CRITICAL)
# ==========================================================================
# Absolute priority: Prevents database keys, API tokens, and JWT secrets from leaking
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
**/.env
**/*.env

# Serverless or cloud provider credentials
.serverless/
.dynamodb/

# ==========================================================================
# 3. COMPILATION OUTPUTS & PRODUCTION BUILDS
# ==========================================================================
# Frontend distribution and build outputs (Vite, CRA, Next.js)
dist/
**/dist/
build/
**/build/
out/
.cache/

# Testing framework coverage metrics
coverage/
**/coverage/
.nyc_output/

# Backend execution application log directories
logs/
*.log
**/logs/

# ==========================================================================
# 4. SYSTEM METADATA & IDE CONFIGURATIONS
# ==========================================================================
# Editor specific setup rules
.vscode/
**/ .vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS-generated thumbnail and folder view caches
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini